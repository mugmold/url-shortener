# ==========================================
# Gateway & Deployment Configuration
# ==========================================
# The domain name for NGINX.
# Use 'localhost' for local Docker testing, or your real domain for production.
DOMAIN_NAME=localhost

# ==========================================
# Database Configuration (Backend)
# ==========================================
# For local Docker Compose: mongodb://mongodb:27017
# For MongoDB Atlas / Remote DB: mongodb+srv://<username>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_URL=mongodb://mongodb:27017
MONGO_DB_NAME=url_shortener_db

# ==========================================
# Security & Authentication (Backend)
# ==========================================
# Generate a secure secret key using: openssl rand -hex 32
SECRET_KEY=your_super_secret_key_here_minimum_32_characters

# (Optional) Token configuration defaults (Backend)
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================================
# Server Configuration (Backend)
# ==========================================
# Set to True to enable Swagger UI (/docs, /openapi.json). Set to False in production.
DEBUG=False

# Format MUST be a valid JSON array string.
CORS_ORIGINS=["http://localhost", "https://yourdomain.com"]